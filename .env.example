NODE_ENV=development

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# API
PORT=4000
CORS_ORIGIN=http://localhost:3000
MONGODB_URI=mongodb://localhost:27017/work
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_CALLBACK_BASE=http://localhost:4000/api/v1/auth/oauth

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── AI assistant ──
# Leave blank → the built-in local assistant is used (free, no key).
# To use a real LLM, set these. FREE option (recommended): Groq.
#   1. Get a free key at https://console.groq.com/keys
#   2. Uncomment the 3 lines below.
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile
#
# Alternatives (also OpenAI-compatible):
#   OpenAI  → OPENAI_API_KEY=sk-... (no BASE_URL needed; AI_MODEL=gpt-4o-mini)
#   OpenRouter → OPENAI_BASE_URL=https://openrouter.ai/api/v1 ; AI_MODEL=meta-llama/llama-3.3-70b-instruct
